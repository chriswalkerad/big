# Zero-config: with NO keys set, the app runs on the deterministic MockProvider.
# Provider priority when configured: Azure (OpenAI-compatible) > Gemini > Mock.

# Azure AI Foundry, via its OpenAI-compatible endpoint (e.g.
# https://<resource>.services.ai.azure.com/openai/v1). Set the endpoint + key to
# use it; deployment defaults to gpt-5.5.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.5

# Voice dictation (streaming speech-to-text). Azure-only, via the real-time Azure
# AI Speech SDK. Set endpoint + key + region (below) to enable the mic affordance.
# This is a separate Speech resource from the chat model above.
#   - endpoint, e.g. https://<region>.api.cognitive.microsoft.com
#   - key: the Speech resource's Ocp-Apim-Subscription-Key
#   - model: the fast-transcription model name, e.g. mai-transcribe-1.5
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
AZURE_SPEECH_TRANSCRIBE_MODEL=mai-transcribe-1.5
# Region for the Speech resource, e.g. eastus. Required for streaming dictation
# (/api/speech-token): the real-time Speech SDK authenticates with a short-lived
# token + region, minted server-side from the key above. The key never leaves the
# server.
AZURE_SPEECH_REGION=

# Google Gemini (used only if Azure is not configured).
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-3.5-flash
