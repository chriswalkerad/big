# Zero-config: with NO keys set, the app runs on the deterministic MockProvider.
# Provider priority when configured: Azure (OpenAI-compatible) > Gemini > Mock.

# Azure AI Foundry, via its OpenAI-compatible endpoint (e.g.
# https://<resource>.services.ai.azure.com/openai/v1). Set the endpoint + key to
# use it; deployment defaults to gpt-5.5.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.5

# Voice dictation (speech-to-text via /api/transcribe). Azure-only. Set a
# transcription deployment/model name (a Whisper model, e.g.
# openai--whisper-large-v3-turbo) to enable the mic affordance; leave blank to
# disable it. By default it reuses the endpoint + key above.
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=
# Optional: a Foundry/HF-hosted transcription model may live on a different
# inference endpoint (and/or use a different key) than the main one above. Set these
# to point the transcription client elsewhere; each falls back to the main value.
AZURE_OPENAI_TRANSCRIBE_ENDPOINT=
AZURE_OPENAI_TRANSCRIBE_API_KEY=

# Google Gemini (used only if Azure is not configured).
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-3.5-flash
